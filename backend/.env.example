# Environment variables for Niscahya AI Chatbot Backend

# API Keys (OPSIONAL - Kalau tidak diisi, bot pakai rule-based responses dari PDF)
# Kosongkan kedua baris di bawah untuk mode gratis tanpa API key
OPENAI_API_KEY=
GOOGLE_API_KEY=

# LLM Configuration
# Pilihan: "gemini", "openai", atau biarkan kosong untuk mode rule-based
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-pro

# Vector Database (Chroma untuk RAG)
CHROMA_PERSIST_DIRECTORY=./chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Database (SQLite untuk development, pakai PostgreSQL untuk production)
DATABASE_URL=sqlite:///./niscahya.db

# Catatan:
# - Jika GOOGLE_API_KEY dan OPENAI_API_KEY kosong, bot akan pakai rule-based response builder
# - Rule-based mode: Gratis, unlimited, tapi jawaban dari template + konteks PDF
# - API key mode: Lebih natural, lebih intelligent, tapi ada rate limit dan biaya

