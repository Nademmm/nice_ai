# Niscahya AI Chatbot - Configuration
# Mode: Rule-Based (Gratis, Unlimited, Tanpa API Key)

# LLM Configuration
# Kosong berarti: pakai rule-based response builder dari PDF + template
OPENAI_API_KEY=
GOOGLE_API_KEY=
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-pro

# Vector Database (Chroma untuk RAG)
CHROMA_PERSIST_DIRECTORY=./chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Database
DATABASE_URL=sqlite:///./niscahya.db
